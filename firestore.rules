rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }
    
    function isClassAdmin(classId) {
      let userData = getUserData();
      return userData != null && userData.classId == classId && userData.role == 'admin';
    }

    function isSuperAdmin() {
      let userData = getUserData();
      return userData != null && userData.isSuperAdmin == true;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Users can only create their own document.
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Super admins can update other users (e.g. changing classId)
      allow update: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      // Users can only delete their own document.
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // Classes Collection
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isSuperAdmin(); // Created by Super Admin
      // Only students joining can update adminCodeUses and admins array, or admins can update
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && isSuperAdmin();
    }

    // Subjects Collection
    match /subjects/{subjectId} {
      allow read: if isAuthenticated() && (getUserData().classId == resource.data.classId || isSuperAdmin());
      // Only admins of the class can create or update subjects
      allow create, update: if isAuthenticated() && isClassAdmin(request.resource.data.classId);
      allow delete: if false;
    }

    // Tasks Collection
    match /tasks/{taskId} {
      // Anyone in the class can read and create tasks
      allow read: if isAuthenticated(); // Simplified: should strictly check subject's classId
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.createdBy || 
        isClassAdmin(resource.data.classId) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completedBy']))
      );
      allow delete: if false;
    }

    // Posts Collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // For confirming/disputing
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.createdBy || isClassAdmin(getUserData().classId));
    }

    // Events Collection
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        // Case 1: Updating RSVP count (limited fields)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['goingCount'])) ||
        // Case 2: Creator editing event (must set status to pending)
        (request.auth.uid == resource.data.createdBy && request.resource.data.status == 'pending') ||
        // Case 3: Super admin moderation
        isSuperAdmin()
      );
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.createdBy || isSuperAdmin());
    }

    // Event Participations Collection
    match /event_participations/{participationId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // Class Change Requests Collection
    match /class_change_requests/{requestId} {
      allow read: if isAuthenticated(); // Users can read their own, admins can read all
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSuperAdmin(); // Super Admins approve/reject
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || request.auth.uid == resource.data.userId);
      allow create: if isAuthenticated() && (isSuperAdmin() || request.auth.uid == request.resource.data.userId);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }

    // Institutes Collection
    match /institutes/{instituteId} {
      allow read: if true; // Public read needed for signup dropdown
      allow write: if isSuperAdmin();
    }
  }
}
